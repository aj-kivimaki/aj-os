NOTION_API_KEY=secret_your_notion_integration_token
# Alternative name also supported:
# NOTION_TOKEN=secret_your_notion_integration_token

# The Notion page ID where databases will be created
NOTION_PARENT_PAGE_ID=your_notion_page_id

# --- Agent + API server ---
# Required to run the API server (npm run serve). The Notion sync CLI ignores these.

# Anthropic API key for the handbook agent
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# Model powering the agent (override to change without code edits)
ANTHROPIC_MODEL=claude-sonnet-5

# Absolute path to the handbook Obsidian vault the agent reads/writes
HANDBOOK_PATH=/Users/aj.kivimaki/Workspace/handbook

# HTTP server bind config. Keep 0.0.0.0 so n8n (Docker) can reach the host.
API_PORT=3000
API_HOST=0.0.0.0
# Shared bearer token n8n must send as: Authorization: Bearer <token>
# Must be at least 16 characters. Generate one, e.g.: openssl rand -hex 32
API_AUTH_TOKEN=change-me-to-a-long-random-secret
