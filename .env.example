# =============================================================================
# AJ-OS environment — copy this file to `.env` and fill in the values you need.
# =============================================================================
# Not every entry point needs every variable. The groups below say which is which.

# -----------------------------------------------------------------------------
# Anthropic — required for AI answers
# -----------------------------------------------------------------------------
# Used by the Knowledge Assistant (`aj ask`) AND the Handbook Agent/API.
# The Knowledge Assistant needs ANTHROPIC_API_KEY to generate answers.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Optional — the model used by the Knowledge Assistant and the agent.
# If unset, each uses its own built-in default.
ANTHROPIC_MODEL=claude-haiku-4-5

# -----------------------------------------------------------------------------
# API server — only for `npm run serve` (REST API + Handbook Agent)
# -----------------------------------------------------------------------------
# The Knowledge Assistant CLI does NOT use these. (It locates its handbook via
# aj.config.json, not HANDBOOK_PATH.)

# Absolute path to the handbook the Agent/API reads and writes.
HANDBOOK_PATH=/absolute/path/to/your/handbook

# HTTP server bind config. Keep 0.0.0.0 so n8n (Docker) can reach the host.
API_PORT=3000
API_HOST=0.0.0.0

# Shared bearer token n8n must send as: Authorization: Bearer <token>
# Must be at least 16 characters. Generate one, e.g.: openssl rand -hex 32
API_AUTH_TOKEN=change-me-to-a-long-random-secret
