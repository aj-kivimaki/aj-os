# Infrastructure env (loaded automatically by docker compose in this directory).
# Copy to infrastructure/.env and fill in. infrastructure/.env is gitignored.

# Public HTTPS base URL of your tunnel to n8n (:5678). Required for chat-app
# triggers (Telegram/Slack/WhatsApp) so n8n can register their webhooks.
# Example (ngrok static domain):   https://your-name.ngrok-free.app
# Example (cloudflared quick tunnel): https://random-words.trycloudflare.com
WEBHOOK_URL=
